<?xml version="1.0" encoding="UTF-8"?>
<PermissionSet xmlns="http://soap.sforce.com/2006/04/metadata">
    <description>Medical Science Liaison user access. Allows capturing insights via Agentforce, viewing dashboards, and accessing related records.</description>
    <hasActivationRequired>false</hasActivationRequired>
    <label>Medical Insights - MSL User</label>

    <!-- Object Permissions -->
    <objectPermissions>
        <allowCreate>true</allowCreate>
        <allowDelete>false</allowDelete>
        <allowEdit>true</allowEdit>
        <allowRead>true</allowRead>
        <modifyAllRecords>false</modifyAllRecords>
        <object>MedicalInsight</object>
        <viewAllRecords>true</viewAllRecords>
    </objectPermissions>

    <objectPermissions>
        <allowCreate>false</allowCreate>
        <allowDelete>false</allowDelete>
        <allowEdit>false</allowEdit>
        <allowRead>true</allowRead>
        <modifyAllRecords>false</modifyAllRecords>
        <object>Subject</object>
        <viewAllRecords>true</viewAllRecords>
    </objectPermissions>

    <objectPermissions>
        <allowCreate>false</allowCreate>
        <allowDelete>false</allowDelete>
        <allowEdit>false</allowEdit>
        <allowRead>true</allowRead>
        <modifyAllRecords>false</modifyAllRecords>
        <object>SubjectAssignment</object>
        <viewAllRecords>true</viewAllRecords>
    </objectPermissions>

    <objectPermissions>
        <allowCreate>false</allowCreate>
        <allowDelete>false</allowDelete>
        <allowEdit>false</allowEdit>
        <allowRead>true</allowRead>
        <modifyAllRecords>false</modifyAllRecords>
        <object>MedicalInsightProduct</object>
        <viewAllRecords>true</viewAllRecords>
    </objectPermissions>

    <objectPermissions>
        <allowCreate>false</allowCreate>
        <allowDelete>false</allowDelete>
        <allowEdit>false</allowEdit>
        <allowRead>true</allowRead>
        <modifyAllRecords>false</modifyAllRecords>
        <object>MedicalInsightAccount</object>
        <viewAllRecords>true</viewAllRecords>
    </objectPermissions>

    <!-- Field Permissions - MedicalInsight Custom Fields (Read Only) -->
    <fieldPermissions>
        <editable>false</editable>
        <field>MedicalInsight.AI_Action_Score__c</field>
        <readable>true</readable>
    </fieldPermissions>

    <fieldPermissions>
        <editable>false</editable>
        <field>MedicalInsight.AI_Cluster_Key__c</field>
        <readable>true</readable>
    </fieldPermissions>

    <fieldPermissions>
        <editable>false</editable>
        <field>MedicalInsight.AI_Confidence__c</field>
        <readable>true</readable>
    </fieldPermissions>

    <fieldPermissions>
        <editable>false</editable>
        <field>MedicalInsight.AI_Redacted__c</field>
        <readable>true</readable>
    </fieldPermissions>

    <fieldPermissions>
        <editable>false</editable>
        <field>MedicalInsight.AI_Model_Version__c</field>
        <readable>true</readable>
    </fieldPermissions>

    <fieldPermissions>
        <editable>false</editable>
        <field>MedicalInsight.AI_Summary__c</field>
        <readable>true</readable>
    </fieldPermissions>

    <!-- Apex Class Access (Limited) -->
    <classAccesses>
        <apexClass>MI_AgentCaptureInvoker</apexClass>
        <enabled>true</enabled>
    </classAccesses>

    <classAccesses>
        <apexClass>MI_AsyncInsightJob</apexClass>
        <enabled>true</enabled>
    </classAccesses>
</PermissionSet>
