<?xml version="1.0" encoding="UTF-8"?>
<PermissionSet xmlns="http://soap.sforce.com/2006/04/metadata">
    <description>Operations Manager access to Medical Insights. Includes analytics, reporting, and insight management without administrative setup capabilities.</description>
    <hasActivationRequired>false</hasActivationRequired>
    <label>Medical Insights - Operations Manager</label>

    <!-- Object Permissions -->
    <objectPermissions>
        <allowCreate>false</allowCreate>
        <allowDelete>false</allowDelete>
        <allowEdit>true</allowEdit>
        <allowRead>true</allowRead>
        <modifyAllRecords>false</modifyAllRecords>
        <object>MedicalInsight</object>
        <viewAllRecords>true</viewAllRecords>
    </objectPermissions>

    <objectPermissions>
        <allowCreate>false</allowCreate>
        <allowDelete>false</allowDelete>
        <allowEdit>false</allowEdit>
        <allowRead>true</allowRead>
        <modifyAllRecords>false</modifyAllRecords>
        <object>Subject</object>
        <viewAllRecords>true</viewAllRecords>
    </objectPermissions>

    <objectPermissions>
        <allowCreate>false</allowCreate>
        <allowDelete>false</allowDelete>
        <allowEdit>false</allowEdit>
        <allowRead>true</allowRead>
        <modifyAllRecords>false</modifyAllRecords>
        <object>SubjectAssignment</object>
        <viewAllRecords>true</viewAllRecords>
    </objectPermissions>

    <objectPermissions>
        <allowCreate>false</allowCreate>
        <allowDelete>false</allowDelete>
        <allowEdit>false</allowEdit>
        <allowRead>true</allowRead>
        <modifyAllRecords>false</modifyAllRecords>
        <object>MedicalInsightProduct</object>
        <viewAllRecords>true</viewAllRecords>
    </objectPermissions>

    <objectPermissions>
        <allowCreate>false</allowCreate>
        <allowDelete>false</allowDelete>
        <allowEdit>false</allowEdit>
        <allowRead>true</allowRead>
        <modifyAllRecords>false</modifyAllRecords>
        <object>MedicalInsightAccount</object>
        <viewAllRecords>true</viewAllRecords>
    </objectPermissions>

    <!-- Field Permissions - MedicalInsight Custom Fields -->
    <fieldPermissions>
        <editable>true</editable>
        <field>MedicalInsight.AI_Action_Score__c</field>
        <readable>true</readable>
    </fieldPermissions>

    <fieldPermissions>
        <editable>true</editable>
        <field>MedicalInsight.AI_Cluster_Key__c</field>
        <readable>true</readable>
    </fieldPermissions>

    <fieldPermissions>
        <editable>false</editable>
        <field>MedicalInsight.AI_Confidence__c</field>
        <readable>true</readable>
    </fieldPermissions>

    <fieldPermissions>
        <editable>true</editable>
        <field>MedicalInsight.AI_Redacted__c</field>
        <readable>true</readable>
    </fieldPermissions>

    <fieldPermissions>
        <editable>false</editable>
        <field>MedicalInsight.AI_Model_Version__c</field>
        <readable>true</readable>
    </fieldPermissions>

    <fieldPermissions>
        <editable>false</editable>
        <field>MedicalInsight.AI_Summary__c</field>
        <readable>true</readable>
    </fieldPermissions>

    <!-- Apex Class Access -->
    <classAccesses>
        <apexClass>MI_InsightsToJsonBuilder</apexClass>
        <enabled>true</enabled>
    </classAccesses>

    <!-- User Permissions -->
    <userPermissions>
        <enabled>true</enabled>
        <name>RunReports</name>
    </userPermissions>

    <userPermissions>
        <enabled>true</enabled>
        <name>CreateReportFolders</name>
    </userPermissions>

    <userPermissions>
        <enabled>true</enabled>
        <name>ViewAllData</name>
    </userPermissions>
</PermissionSet>
